{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020", "DOM"],
    "outDir": "./static/js",
    "rootDir": "./static/ts",
    "removeComments": false,
    "sourceMap": true
  },
  "include": ["static/ts/**/*.ts"]
}
